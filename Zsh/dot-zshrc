			# ---------- Functions ---------- #
			conf() {
					local dir
					if [ -z "$1" ]; then
						dir="."
					else
						dir="$1"
						[ ! -d "$dir" ] && echo "Directory does not exist: $dir" && return 1
					fi
					owner=$(stat -c %U "$dir")
					if [ "$owner" = "root" ]; then
						find "$dir" -type f | fzf --preview 'bat --color=always --theme Dracula {}' | xargs -I{} sudoedit {}
					else
						find "$dir" -type f | fzf --preview 'bat --color=always --theme Dracula {}' | xargs -I{} nvim {}
					fi						
			}

			connect() {
					if [ -z "$1" ]; then
						echo device not found scanning...
						nmcli device wifi list --rescan yes
					else
						nmcli device wifi list --rescan yes > /dev/null
						sid="$1"
						if [ -z "$2" ]; then
							nmcli device wifi connect $sid
						elif [ "$2" = "-a" ]; then
							nmcli device wifi connect $sid --ask
						fi
					fi
			}

			export EDITOR='nvim'
			export VISUAL='nvim'
			eval "$(fzf --zsh)"
			export FZF_DEFAULT_OPTS="--layout=reverse --border=bold --border=rounded --margin=3% --color=dark"


			#tmux new -As$(pgrep -c alacritty)
			tmux new -As$(pgrep -c kitty)
			clear
			fastfetch

			# To get back to zsh run "zsh --norc"
